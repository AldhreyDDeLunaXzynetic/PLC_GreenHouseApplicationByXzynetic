<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="100dp" />
            <gradient
                android:angle="0"
                android:startColor="#059669"
                android:centerColor="#10B981"
                android:endColor="#84CC16" />
            <stroke
                android:width="2dp"
                android:color="#D9FF99" />
        </shape>
    </item>

    <item android:state_enabled="false">
        <shape>
            <corners android:radius="100dp" />
            <solid android:color="#6B7280" />
        </shape>
    </item>

    <item>
        <shape>
            <corners android:radius="100dp" />
            <gradient
                android:angle="0"
                android:startColor="#49D983"
                android:centerColor="#22C55E"
                android:endColor="#A3E635" />
            <stroke
                android:width="2dp"
                android:color="#D9FF99" />
        </shape>
    </item>
</selector>